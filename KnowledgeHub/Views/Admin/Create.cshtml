@model KnowledgeHub.Models.Post

@{
    ViewData["Title"] = "Create Post";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">Create New Blog</h2>
            <p class="text-muted mb-0">Publish a new article to your website.</p>
        </div>

        <a asp-action="Posts" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>

    </div>

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-body p-4">

            <form asp-action="Create"
                  method="post"
                  enctype="multipart/form-data">

                <div class="row">

                    <div class="col-md-8">

                        <div class="mb-3">

                            <label class="form-label fw-semibold">Title</label>

                            <input asp-for="Title"
                                   class="form-control form-control-lg"
                                   placeholder="Enter blog title" />

                        </div>

                        <div class="mb-3">

                            <label class="form-label fw-semibold">Slug</label>

                            <input asp-for="Slug"
                                   class="form-control"
                                   placeholder="blog-title" />

                        </div>

                        <div class="mb-3">

                            <label class="form-label fw-semibold">Short Description</label>

                            <textarea asp-for="ShortDescription"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Short description"></textarea>

                        </div>

                        <div class="mb-3">

                            <label class="form-label fw-semibold">Description</label>

                            <textarea asp-for="Description"
                                      id="editor"
                                      rows="12"
                                      class="form-control"></textarea>

                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="card bg-light border-0">

                            <div class="card-body">

                                <h5>Featured Image</h5>

                                <img id="preview"
                                     src="https://placehold.co/500x300?text=Preview"
                                     class="img-fluid rounded mb-3 border">

                                <input type="file"
                                       id="ImageFile"
                                       name="ImageFile"
                                       class="form-control">

                            </div>

                        </div>

                        <div class="card bg-light border-0 mt-3">

                            <div class="card-body">

                                <h5>Publish</h5>

                                <div class="form-check">

                                    <input asp-for="IsPublished"
                                           class="form-check-input">

                                    <label class="form-check-label">
                                        Publish immediately
                                    </label>

                                </div>

                                <hr>

                                <button class="btn btn-success w-100">

                                    <i class="bi bi-check-circle"></i>

                                    Save Post

                                </button>

                            </div>

                        </div>

                    </div>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/classic/ckeditor.js"></script>

    <script>

        ClassicEditor
        .create(document.querySelector('#editor'));

        document.getElementById('ImageFile')
        .addEventListener('change',function(e){

        if(e.target.files.length>0){

        const reader=new FileReader();

        reader.onload=function(x){

        document.getElementById("preview").src=x.target.result;

        }

        reader.readAsDataURL(e.target.files[0]);

        }

        });

    </script>

}